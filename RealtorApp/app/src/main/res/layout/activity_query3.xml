<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:paddingTop="50dp">   <!-- ← Важно! Отступ сверху от "брови" -->

    <!-- Заголовок -->

    <!-- Выбор дома -->

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="Свободные квартиры в доме"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Выберите дом:"
        android:textSize="16sp"
        android:layout_marginBottom="6dp"/>

    <!-- Максимальная площадь -->
    <Spinner
        android:id="@+id/spinnerHouse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Максимальная площадь (м²)"
        android:textSize="16sp"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etMaxArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Например: 50"
        android:inputType="numberDecimal"
        android:layout_marginBottom="24dp"/>

    <!-- Кнопка -->
    <Button
        android:id="@+id/btnSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="НАЙТИ СВОБОДНЫЕ КВАРТИРЫ"
        android:padding="12dp"/>

    <!-- Список результатов -->
    <ListView
        android:id="@+id/listView"
        android:layout_width="match_parent"
        android:layout_height="329dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />
</LinearLayout>