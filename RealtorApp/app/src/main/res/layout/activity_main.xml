<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:text="РИЭЛТОР"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnQuery1"
        android:text="а) Проданные квартиры в доме"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnQuery2"
        android:text="б) Свободные квартиры (площадь + комнаты, 2-3 этаж)"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnQuery3"
        android:text="в) Свободные в доме (площадь ≤ + раздельный санузел)"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>
